<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Criar Perfil - AoP</title>
    <style>
        body {
            background-color: #121212;
            color: #ffffff;
            font-family: Arial, sans-serif;
            margin: 30px;
            padding: 0;
            font-size: 25px;
        }

        h1 {
            color: #ffffff;
            text-align: left;
            margin: 20px 0 20px 20px;
        }

        .container {
            padding: 20px;
            width: 85%;
            border-radius: 40px;
            display: inline-block;
            text-align: left;
            vertical-align: top;
            margin-bottom: 50px;
        }

        .content {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        input[type="text"], select {
            width: 100%;
            padding: 15px;
            margin: 10px 0;
            border: 2px solid #888888;
            border-radius: 8px;
            background-color: #2a2a2a;
            color: #ffffff;
            font-size: 18px;
        }

        .profile-options {
            display: flex;
            align-items: center;
            margin: 15px 0;
        }

        .profile-options input[type="checkbox"] {
            width: 20px;
            height: 20px;
            margin-right: 15px;
        }

        .gender-language {
            display: flex;
            gap: 20px;
            margin: 20px 0;
        }

        .gender-language select {
            flex: 1;
        }

        .ratings {
            display: flex;
            gap: 10px;
            margin: 20px 0;
            justify-content: center;
        }

        .ratings img {
            width: 80px;
            height: auto;
            cursor: pointer;
            border: 3px solid transparent;
            border-radius: 8px;
            transition: border-color 0.3s ease;
        }

        .ratings img.selected {
            border-color: #4CAF50;
        }

        .accessibility-options {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin: 30px 0;
        }

        .accessibility-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            cursor: pointer;
            padding: 15px;
            border: 2px solid transparent;
            border-radius: 12px;
            transition: border-color 0.3s ease;
            min-width: 120px;
        }

        .accessibility-item.selected {
            border-color: #4CAF50;
            background-color: #1a4a1a;
        }

        .accessibility-item img {
            width: 60px;
            height: 60px;
            margin-bottom: 10px;
        }

        .avatar-section {
            text-align: center;
            padding: 20px;
            margin-left: 30px;
        }

        .avatar-button {
            background: none;
            border: 3px solid #888888;
            border-radius: 50%;
            padding: 10px;
            cursor: pointer;
            transition: border-color 0.3s ease;
        }

        .avatar-button:hover {
            border-color: #4CAF50;
        }

        .avatar-button img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
        }

        .terms-actions {
            margin-top: 30px;
        }

        .terms {
            margin: 20px 0;
            display: flex;
            align-items: flex-start;
            gap: 15px;
        }

        .terms input[type="checkbox"] {
            width: 20px;
            height: 20px;
            margin-top: 5px;
        }

        .actions {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin-top: 30px;
        }

        .btn {
            padding: 15px 30px;
            border: 2px solid #888888;
            border-radius: 8px;
            background-color: #2a2a2a;
            color: #ffffff;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn:hover {
            background-color: #4CAF50;
            border-color: #4CAF50;
        }

        .btn.advance {
            background-color: #4CAF50;
            border-color: #4CAF50;
        }

        .btn.advance:hover {
            background-color: #45a049;
        }

        a {
            color: #4CAF50;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }
    </style>
    <script src="/jquery-3.7.1.min.js"></script>
    <script src="/navigation.js"></script>
</head>
<body>
    <h1>Criando seu Perfil Smart TV</h1>
    
    <div class="content">
        <div class="container">
            <form id="profile-form">
                <input type="text" id="name" name="name" placeholder="Nome do perfil (obrigatório)" required>
                
                <!-- Perfil de grupo -->
                <div class="profile-options">
                    <input type="checkbox" id="group-profile" name="group-profile">
                    <label for="group-profile">Este é um Perfil de Grupo (ex.: família, hóspedes...)</label>
                </div>
                
                <div class="gender-language">
                    <select id="language" name="language">
                        <option value="pt-br">Idioma selecionado: Português</option>
                        <option value="en">Idioma selecionado: Inglês</option>
                    </select>
                    <select id="gender" name="gender">
                        <option value="M">Masculino</option>
                        <option value="F">Feminino</option>
                        <option value="NB">Não Binário</option>
                    </select>
                </div>
                
                <div class="Group-classification">
                    <div class="profile-options">
                        <input type="checkbox" id="child-profile" name="child-profile">
                        <label for="child-profile">Este é um Perfil de Criança</label>
                    </div>
                    <div class="ratings">
                        <img id="livre" src="/media/Livre.png" alt="Livre" onclick="selectRating('livre')">
                        <img id="10anos" src="/media/10anos.png" alt="10 anos" onclick="selectRating('10anos')">
                        <img id="12anos" src="/media/12anos.png" alt="12 anos" onclick="selectRating('12anos')">
                        <img id="14anos" src="/media/14anos.png" alt="14 anos" onclick="selectRating('14anos')">
                        <img id="16anos" src="/media/16anos.png" alt="16 anos" onclick="selectRating('16anos')">
                        <img id="18anos" src="/media/18anos.png" alt="18 anos" onclick="selectRating('18anos')">
                    </div>
                </div>
                
                <!-- Botões de Acessibilidade -->
                <div class="accessibility-options">
                    <div class="accessibility-item" onclick="toggleAccessibility('audio-description')">
                        <img id="audio-description" src="/media/audio-description.png" alt="Audiodescrição">
                        <label>Audiodescrição</label>
                    </div>
                    <div class="accessibility-item" onclick="toggleAccessibility('sign-language')">
                        <img id="sign-language" src="/media/sign-language.png" alt="Acessível em Libras">
                        <label>Acessível em Libras</label>
                    </div>
                    <div class="accessibility-item" onclick="toggleAccessibility('closed-caption')">
                        <img id="closed-caption" src="/media/closed-caption.png" alt="Legendas ocultas">
                        <label>Legendas ocultas</label>
                    </div>
                    <div class="accessibility-item" onclick="toggleAccessibility('dialogue-enhancement')">
                        <img id="dialogue-enhancement" src="/media/dialogue-enhancement.png" alt="Aprimoramento de Diálogo">
                        <label>Aprim. de Diálogo</label>
                    </div>
                </div>
            </form>
        </div>
        
        <!-- Seção de Avatar -->
        <div class="avatar-section">
            <button type="button" class="avatar-button" onclick="openAvatarSelection()">
                <img id="selected-avatar" src="/media/profile.png" alt="Escolher Avatar">
            </button>
            <label>Escolha seu Avatar:</label>
        </div>
    </div>
    
    <div class="terms-actions">
        <!-- Seção de Termos -->
        <div class="terms">
            <input type="checkbox" id="terms" name="terms" required>
            <label for="terms">
                Concordo com a coleta e processamento de meus dados para uma melhor experiência, em conformidade com a Lei Geral de Proteção de Dados Pessoais (LGPD).
                <a href="#">Saiba mais.</a>
            </label>
        </div>
        
        <!-- Botões -->
        <div class="actions">
            <button type="button" class="btn create" onclick="createAnother()">Criar Outro</button>
            <button type="button" class="btn advance" onclick="saveProfile()">Avançar</button>
        </div>
    </div>

    <script>
        // Funções do Profile Creation adaptadas para o AoP
        
        function selectRating(ratingId) {
            const ratings = document.querySelectorAll('.ratings img');
            ratings.forEach(rating => {
                rating.classList.remove('selected');
            });
            const selectedRating = document.getElementById(ratingId);
            selectedRating.classList.add('selected');
        }

        function toggleAccessibility(accessibilityId) {
            const element = document.getElementById(accessibilityId).parentElement;
            element.classList.toggle('selected');
        }

        function openAvatarSelection() {
            // Por enquanto, vamos usar um avatar aleatório
            // Futuramente pode implementar seleção de avatar
            alert('Seleção de avatar será implementada em breve!');
        }

        function saveProfile() {
            const name = document.getElementById('name').value;
            const groupProfile = document.getElementById('group-profile').checked;
            const childProfile = document.getElementById('child-profile').checked;
            const gender = document.getElementById('gender').value;
            const language = document.getElementById('language').value;

            const selectedRating = document.querySelector('.ratings img.selected');
            const ageRating = selectedRating ? selectedRating.id : null;

            const captions = document.getElementById('closed-caption').parentElement.classList.contains('selected');
            const signLanguageWindow = document.getElementById('sign-language').parentElement.classList.contains('selected');
            const audioDescription = document.getElementById('audio-description').parentElement.classList.contains('selected');
            const dialogueEnhancement = document.getElementById('dialogue-enhancement').parentElement.classList.contains('selected');

            if (!name || !document.getElementById('terms').checked) {
                alert('Por favor, preencha todos os campos obrigatórios e aceite os termos.');
                return;
            }

            const newProfile = {
                name,
                isGroup: groupProfile,
                parentalControl: childProfile,
                gender,
                language,
                ageRating,
                captions,
                signLanguageWindow,
                audioDescription,
                dialogueEnhancement
            };

            // Enviar para o endpoint do AoP
            fetch('/profile/create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(newProfile)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Perfil criado com sucesso!');
                    // Voltar para a tela de perfis
                    window.location.href = '/profile';
                } else {
                    alert('Erro ao criar perfil: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro ao criar perfil.');
            });
        }

        function createAnother() {
            // Limpar formulário para criar outro perfil
            document.getElementById('profile-form').reset();
            document.querySelectorAll('.ratings img.selected').forEach(img => img.classList.remove('selected'));
            document.querySelectorAll('.accessibility-item.selected').forEach(item => item.classList.remove('selected'));
        }

        // Navegação com teclado (integração com o AoP)
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                window.location.href = '/profile';
            }
        });
    </script>
</body>
</html>
