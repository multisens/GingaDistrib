<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <style>
      html,
      body {
        height: 100%;
        margin: 0;
        overflow: hidden; /* Esconde barras de rolagem */
      }
      body {
        font-family: sans-serif;
        text-align: center;
        color: white;

        background-image: url("media/eduplay/images/quiz-screen.png");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
      }
      .container {
        display: none; /* Todos os contêineres começam escondidos por padrão */
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
      }
      #main-video {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover; /* Garante que o vídeo cubra toda a tela */
        z-index: 1;
      }
      /* --- NOVO: Estilo para o QR Code como um overlay --- */
      #qrcode-overlay {
        display: none; /* Começa escondido */
        position: fixed;
        bottom: 30px;
        right: 30px;
        padding: 10px;
        background-color: white;
        border-radius: 8px;
        z-index: 100;
      }
      #question-text {
        font-size: 3em;
        margin: 40px 20px;
      }
      #options-list {
        list-style-type: none;
        padding: 0;
        font-size: 1.8em;
        display: grid;
        grid-template-columns: 1fr;
        gap: 15px;
        width: 80%;
        max-width: 1000px;
      }
      #options-list li {
        padding: 20px;
        border-radius: 5px;
        text-align: left;
        padding-left: 25px;
      }
      .option-red {
        background-color: #cc4637;
      }
      .option-green {
        background-color: #27ae60;
      }
      .option-yellow {
        background-color: #dab200;
        color: #333;
      }
      .option-blue {
        background-color: #1f75af;
      }
      .correct-answer {
        border: 5px solid #fff;
        transform: scale(1.05);
      }
      /* --- NOVO: Estilo para a tela de estatísticas --- */
      #stats-container {
        font-size: 2.5em;
      }
      #stats-container .stat {
        margin: 20px;
      }
      .stat-correct {
        color: #2ecc71;
      }
      .stat-incorrect {
        color: #e74c3c;
      }
    </style>
  </head>
  <body>
    <video id="main-video" autoplay muted playsinline></video>

    <div id="qrcode-overlay">
      <div id="qrcode"></div>
    </div>

    <div id="question-container" class="container">
      <div id="question-text"></div>
      <ul id="options-list"></ul>
    </div>

    <div id="stats-container" class="container">
      <h1>Resultados</h1>
      <div id="stats-details"></div>
    </div>

    <div id="end-container" class="container">
      <h1>O Quiz terminou!</h1>
      <p>Obrigado por jogar.</p>
    </div>

    <script src="/jquery-3.7.1.min.js"></script>
    <script src="/navigation.js"></script>
    <script src="/bootstrap.js"></script>

    <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
    <script src="https://cdn.rawgit.com/davidshimjs/qrcodejs/gh-pages/qrcode.min.js"></script>

    <script>
      window.addEventListener("message", receiveFrameMessage);
      postFrameMessage({ type: "loaded" });

      function handleKey(k) {
        if (k == "Escape") {
          back();
        }
      }

      const roomId = "<%= roomId %>";
      const playerUrl = "<%= playerUrl %>";
      const socket = io("<%= logicServerUrl %>");

      // Mapeamento dos elementos da página
      const videoPlayer = document.getElementById("main-video");
      const qrCodeOverlay = document.getElementById("qrcode-overlay");
      const questionContainer = document.getElementById("question-container");
      const statsContainer = document.getElementById("stats-container");
      const endContainer = document.getElementById("end-container");
      const questionTextEl = document.getElementById("question-text");
      const optionsListEl = document.getElementById("options-list");

      // --- Lógica de Conexão ---
      socket.on("connect", () => {
        console.log(
          "Conectado. Registrando como apresentador da sala:",
          roomId
        );
        socket.emit("joinRoom", { roomId: roomId, isPresenter: true });
      });

      // --- Lógica para Lidar com Eventos do Servidor ---

      // NOVO: Ouve o evento para tocar o vídeo de introdução
      socket.on("playIntroVideo", (introVideo) => {
        console.log("Iniciando vídeo de introdução:", introVideo.src);
        videoPlayer.style.display = "block";
        videoPlayer.src = introVideo.src;
        videoPlayer.play();

        // Agenda a aparição do QR Code
        setTimeout(() => {
          new QRCode(document.getElementById("qrcode"), playerUrl);
          qrCodeOverlay.style.display = "block";
          console.log("QR Code apareceu.");
        }, introVideo.qrCodeDelay * 1000);

        // Agenda o desaparecimento do QR Code
        setTimeout(() => {
          qrCodeOverlay.style.display = "none";
          console.log("QR Code desapareceu.");
        }, (introVideo.qrCodeDelay + introVideo.qrCodeDuration) * 1000);
      });

      socket.on("playVideo", ({ url }) => {
        console.log(`Recebido comando para tocar o vídeo: ${url}`);
        // Esconde as outras telas e mostra o vídeo
        questionContainer.style.display = "none";
        statsContainer.style.display = "none";
        videoPlayer.style.display = "block";
        videoPlayer.src = url;
        videoPlayer.play();
      });

      socket.on("quiz:newQuestion", (question) => {
        console.log("Nova pergunta recebida:", question.text);
        videoPlayer.style.display = "none"; // Esconde o vídeo
        statsContainer.style.display = "none";
        questionContainer.style.display = "flex"; // Mostra a pergunta

        questionTextEl.innerText = question.text;
        optionsListEl.innerHTML = "";

        const prefixes = ["A)", "B)", "C)", "D)"];
        const colorClasses = ["option-red", "option-green", "option-yellow", "option-blue"];

        question.options.forEach((optionText, index) => {
          const li = document.createElement("li");
          li.classList.add(colorClasses[index % colorClasses.length]);
          li.innerText = `${prefixes[index]} ${optionText}`;
          optionsListEl.appendChild(li);
        });
      });

      // MODIFICADO: Agora também exibe as estatísticas de acertos/erros
      socket.on(
        "quiz:endQuestion",
        ({ results, correctAnswerIndex, stats }) => {
          console.log(
            "Fim da pergunta. Exibindo resultados e estatísticas:",
            stats
          );
          questionContainer.style.display = "none";
          statsContainer.style.display = "flex";

          const statsDetails = document.getElementById("stats-details");
          statsDetails.innerHTML = `
            <div class="stat stat-correct">Acertos: ${stats.correct}</div>
            <div class="stat stat-incorrect">Erros: ${stats.incorrect}</div>
        `;
        }
      );

      socket.on("quizEnded", (message) => {
        console.log(message);
        videoPlayer.style.display = "none";
        questionContainer.style.display = "none";
        statsContainer.style.display = "none";
        endContainer.style.display = "flex";
      });
    </script>
  </body>
</html>
